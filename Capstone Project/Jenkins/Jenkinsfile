pipeline {

    agent any

    environment {
        IMAGE_NAME = "teju96/capstone-project"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    credentialsId: 'Github-token',
                    url: 'https://github.com/Tejashwini-Javejar/orn-ai-devops-assessment.git'
            }
        }


        stage('Install Dependencies') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                python -m pip install --upgrade pip
                python -m pip install -r requirements.txt
                '''
            }
        }


        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    sonar-scanner \
                    -Dsonar.projectKey=capstone-project \
                    -Dsonar.sources=. \
                    -Dsonar.exclusions=venv/**,.git/**
                    '''
                }
            }
        }


        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                '''
            }
        }


        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {

                    sh '''
                    echo $DOCKER_PASSWORD | docker login -u $DOCKER_USERNAME --password-stdin

                    docker push ${IMAGE_NAME}:${IMAGE_TAG}

                    docker logout
                    '''
                }
            }
        }


        stage('Update Deployment') {
            steps {
                sh '''
                sed -i "s|image:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|" deployment.yaml

                echo "Updated deployment file:"
                cat deployment.yaml
                '''
            }
        }

    }


    post {

        success {
            echo "Build and deployment pipeline completed successfully!"
        }

        failure {
            echo "Pipeline failed. Please check the logs."
        }

        always {
            cleanWs()
        }

    }
}
